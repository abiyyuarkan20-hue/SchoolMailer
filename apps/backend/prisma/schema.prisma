generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Tabel Users — untuk login staf/admin
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          Role      @default(STAFF)
  refreshToken  String?   @map("refresh_token") @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  templates     Template[]
  generationLogs GenerationLog[]

  @@map("users")
}

enum Role {
  ADMIN
  STAFF
}

// ─────────────────────────────────────────────
// Tabel Students — data lengkap siswa
// ─────────────────────────────────────────────
model Student {
  id          String   @id @default(cuid())
  nisn        String   @unique                // Nomor Induk Siswa Nasional
  name        String
  grade       String                          // Tingkat: "X", "XI", "XII"
  className   String   @map("class_name")     // Kelas: "X-A", "XI-IPA-1"
  gender      Gender
  parentName  String   @map("parent_name")
  parentPhone String?  @map("parent_phone")
  address     String?  @db.Text
  email       String?
  extraData   Json?    @map("extra_data")     // Field dinamis tambahan dari CSV
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  generationLogs GenerationLog[]

  @@index([className])
  @@index([grade])
  @@map("students")
}

// ─────────────────────────────────────────────
// Tabel Teachers — data lengkap guru
// ─────────────────────────────────────────────
model Teacher {
  id          String   @id @default(cuid())
  nip         String   @unique
  nik         String?
  name        String
  position    String   @map("position")
  pangkat     String?
  subject     String?
  gender      Gender
  phone       String?
  email       String?
  address     String?  @db.Text
  nuptk       String?
  status      String?
  education   String?
  unitKerja   String?  @map("unit_kerja")
  instansi    String?
  birthPlace  String?  @map("birth_place")
  birthDate   DateTime? @map("birth_date")
  extraData   Json?    @map("extra_data")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([position])
  @@index([subject])
  @@index([nip])
  @@map("teachers")
}

enum Gender {
  MALE
  FEMALE
}

// ─────────────────────────────────────────────
// Tabel Templates — template surat dengan variabel
// ─────────────────────────────────────────────
model Template {
  id              String        @id @default(cuid())
  title           String
  letterType      LetterType    @map("letter_type")
  description     String?       @db.Text
  htmlContent     String        @map("html_content") @db.Text  // Template HTML penuh
  cssStyles       String?       @map("css_styles") @db.Text    // CSS kustom per template
  headerConfig    Json?         @map("header_config")           // Konfigurasi Kop Surat (logo, instansi, dll)
  variables       Json                                          // ["{{nama_siswa}}", "{{kelas}}"]
  pageSize        String        @default("A4") @map("page_size") // A4, F4, Letter
  pageOrientation String        @default("portrait") @map("page_orientation")
  marginTop       Int           @default(25) @map("margin_top")     // Margin atas (mm)
  marginRight     Int           @default(25) @map("margin_right")   // Margin kanan (mm)
  marginBottom    Int           @default(25) @map("margin_bottom")  // Margin bawah (mm)
  marginLeft      Int           @default(30) @map("margin_left")    // Margin kiri (mm)
  isActive        Boolean       @default(true) @map("is_active")
  version         Int           @default(1)
  createdBy       String        @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  creator         User          @relation(fields: [createdBy], references: [id])
  generationLogs  GenerationLog[]

  @@map("templates")
}

enum LetterType {
  PARENT_SUMMON       // Surat Panggilan Orang Tua
  CIRCULAR            // Surat Edaran
  CERTIFICATE         // Surat Keterangan
  PERMISSION          // Surat Izin
  RECOMMENDATION      // Surat Rekomendasi
  CUSTOM              // Kustom
}

// ─────────────────────────────────────────────
// Tabel GenerationLogs — audit trail setiap generate
// ─────────────────────────────────────────────
model GenerationLog {
  id              String          @id @default(cuid())
  templateId      String          @map("template_id")
  generatedBy     String          @map("generated_by")
  
  // Metadata generate
  studentIds      String[]        @map("student_ids")   // Array ID siswa yang dipilih
  studentCount    Int             @map("student_count")
  filterClass     String?         @map("filter_class")  // Filter kelas yang dipakai
  outputType      OutputType      @map("output_type")   // PDF_SINGLE atau ZIP_BUNDLE
  
  // Status & hasil
  status          GenerationStatus @default(PENDING)
  filePath        String?         @map("file_path")     // Path file output di server
  fileSize        BigInt?         @map("file_size")     // Ukuran file dalam bytes
  downloadCount   Int             @default(0) @map("download_count")
  errorMessage    String?         @map("error_message") @db.Text
  
  // Timing
  startedAt       DateTime?       @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  expiresAt       DateTime?       @map("expires_at")    // File dihapus otomatis setelah X jam
  createdAt       DateTime        @default(now()) @map("created_at")

  template        Template        @relation(fields: [templateId], references: [id])
  generatedByUser User            @relation(fields: [generatedBy], references: [id])
  students        Student[]

  @@index([templateId])
  @@index([generatedBy])
  @@index([status])
  @@map("generation_logs")
}

// ─────────────────────────────────────────────
// Tabel Settings — konfigurasi global
// ─────────────────────────────────────────────
model Setting {
  id        String   @id @default("global_settings")
  // Konfigurasi Kop Surat
  useGlobalHeader Boolean @default(false)
  headerInstansi  String?
  headerSekolah   String?
  headerAlamat    String?
  headerKontak    String?
  headerContentHtml String? @db.Text
  headerLogoLeft  String?
  headerLogoRight String?
  logoSize        Int      @default(80)
  logoMarginTop   Int      @default(0)
  logoPaddingX    Int      @default(0)

  // Konfigurasi Garis Kop Surat
  headerLineWidth     Int      @default(100)
  headerLineAlign     String   @default("center")
  headerLinePosition  String   @default("bottom")
  headerLinePadding   Int      @default(15)

  customVariables String[] @default([])

  // Konfigurasi Tanda Tangan
  useGlobalSignature Boolean @default(false)
  signatureConfig    Json?

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
// ─────────────────────────────────────────────
// Tabel AuditLog — log aktivitas sensitif
// ─────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String                        // LOGIN_SUCCESS, LOGIN_FAILED, LOGOUT, DELETE_ALL, IMPORT, etc.
  details   String?  @db.Text             // JSON extra info (email attempted, count, etc.)
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum OutputType {
  PDF_SINGLE    // Satu PDF, banyak halaman
  ZIP_BUNDLE    // ZIP berisi PDF per siswa
}

enum GenerationStatus {
  PENDING       // Antri
  PROCESSING    // Sedang diproses
  COMPLETED     // Selesai
  FAILED        // Gagal
}
