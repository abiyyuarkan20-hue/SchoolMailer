# Database
DATABASE_URL="postgresql://user:password@localhost:5432/schoolmailer_db?schema=public"

# JWT — minimal 32 karakter, harus unik satu sama lain
JWT_ACCESS_SECRET="ganti-dengan-random-secret-64-char"
JWT_REFRESH_SECRET="ganti-dengan-random-secret-64-char-berbeda"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Server
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# File Storage
OUTPUT_DIR="./storage/outputs"
TEMP_DIR="./storage/temp"
MAX_UPLOAD_SIZE_MB=10
OUTPUT_FILE_TTL_HOURS=24
